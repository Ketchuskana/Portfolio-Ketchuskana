<!DOCTYPE html>
<html lang="fr" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{{ name }} — Développeuse Fullstack{% endblock %}</title>
    {% block stylesheets %}
        <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
    {% endblock %}
    {% block importmap %}{{ importmap('app') }}{% endblock %}
    <style>
        /* ── Glitch loader ── */
        .glitch-text { position: relative; display: inline-block; }
        .glitch-text::before,
        .glitch-text::after {
            content: attr(data-text);
            position: absolute;
            top: 0; left: 0;
            width: 100%; height: 100%;
            pointer-events: none;
            font-size: inherit;
            font-weight: inherit;
            letter-spacing: inherit;
        }
        .glitch-text::before {
            animation: glitch-a 3s infinite linear;
            color: #818cf8;
            clip-path: polygon(0 0, 100% 0, 100% 40%, 0 40%);
        }
        .glitch-text::after {
            animation: glitch-b 3s infinite linear reverse;
            color: #c084fc;
            clip-path: polygon(0 60%, 100% 60%, 100% 100%, 0 100%);
        }
        @keyframes glitch-a {
            0%,88%,100% { transform: translate(-3px, 0); opacity:.8; }
            90%          { transform: translate( 4px,-2px); opacity:.9; }
            92%          { transform: translate(-4px, 2px); opacity:.7; }
            94%          { transform: translate( 2px, 0);   opacity:.9; }
            96%          { transform: translate(-2px,-1px); opacity:.8; }
        }
        @keyframes glitch-b {
            0%,88%,100% { transform: translate( 3px, 0); opacity:.8; }
            90%          { transform: translate(-4px, 2px); opacity:.9; }
            92%          { transform: translate( 4px,-2px); opacity:.7; }
            94%          { transform: translate(-2px, 0);   opacity:.9; }
            96%          { transform: translate( 2px, 1px); opacity:.8; }
        }
        /* Loader scanline */
        .scanline {
            position: absolute; left: 0; width: 100%; height: 2px;
            background: linear-gradient(90deg,transparent,rgba(129,140,248,.35),transparent);
            animation: scan 2.5s linear infinite;
        }
        @keyframes scan { 0%{top:-2px} 100%{top:100%} }

        /* Section reveal */
        .reveal { opacity:0; transform:translateY(28px); transition:opacity .7s ease,transform .7s ease; }
        .reveal.visible { opacity:1; transform:none; }

        /* Nav active */
        .nav-link.active { color: #818cf8; }
    </style>
</head>
<body class="bg-gradient-to-b from-slate-950 via-slate-900 to-slate-950 text-white" id="body-content">

    <!-- ── LOADER ── -->
    <div id="loader" class="fixed inset-0 z-[100] flex items-center justify-center bg-slate-950 overflow-hidden">
        <!-- scanline -->
        <div class="scanline"></div>
        <!-- grid bg -->
        <div class="absolute inset-0 opacity-[.04]"
             style="background-image:linear-gradient(rgba(129,140,248,1) 1px,transparent 1px),linear-gradient(90deg,rgba(129,140,248,1) 1px,transparent 1px);background-size:56px 56px"></div>
        <!-- corner brackets -->
        <div class="absolute top-8 left-8  w-10 h-10 border-t-2 border-l-2 border-indigo-500/40"></div>
        <div class="absolute top-8 right-8 w-10 h-10 border-t-2 border-r-2 border-indigo-500/40"></div>
        <div class="absolute bottom-8 left-8  w-10 h-10 border-b-2 border-l-2 border-indigo-500/40"></div>
        <div class="absolute bottom-8 right-8 w-10 h-10 border-b-2 border-r-2 border-indigo-500/40"></div>
        <!-- spinning rings -->
        <div class="absolute w-72 h-72 border border-indigo-500/10 rounded-full animate-spin" style="animation-duration:12s"></div>
        <div class="absolute w-52 h-52 border border-purple-500/15 rounded-full animate-spin" style="animation-duration:8s;animation-direction:reverse"></div>

        <div class="relative text-center px-8">
            <p class="text-xs font-mono tracking-widest text-indigo-500/50 mb-4 uppercase">&lt; portfolio /&gt;</p>
            <h1 class="glitch-text text-4xl md:text-6xl font-black tracking-tight text-transparent bg-clip-text bg-gradient-to-r from-indigo-400 via-white to-purple-400"
                data-text="{{ name|upper }}">{{ name|upper }}</h1>
            <p class="mt-3 text-sm text-slate-400 font-mono tracking-wide">Développeuse Fullstack — Symfony / React</p>

            <!-- progress bar -->
            <div class="mt-10 w-64 mx-auto">
                <div class="h-px bg-slate-800 overflow-hidden rounded-full">
                    <div id="loader-bar" class="h-full bg-gradient-to-r from-indigo-500 to-purple-500 w-0 transition-none rounded-full"></div>
                </div>
                <div class="flex justify-between mt-2 text-xs font-mono text-slate-500">
                    <span>LOADING</span>
                    <span id="loader-pct">0%</span>
                </div>
            </div>
        </div>
    </div>

    <!-- ── NAVBAR ── -->
    <header id="navbar" class="fixed top-0 w-full z-50 transition-all duration-300" style="background:rgba(15,23,42,0)">
        <nav class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
            <a href="#hero" class="text-xl font-black font-mono bg-gradient-to-r from-indigo-400 to-purple-400 bg-clip-text text-transparent hover:scale-105 transition-transform">
                &lt;KSE /&gt;
            </a>
            <ul class="hidden md:flex space-x-1 text-sm font-medium">
                <li><a href="#hero"     class="nav-link px-4 py-2 rounded-lg transition-all hover:text-indigo-400">Accueil</a></li>
                <li><a href="#stack"    class="nav-link px-4 py-2 rounded-lg transition-all hover:text-indigo-400">Stack</a></li>
                <li><a href="#skills"   class="nav-link px-4 py-2 rounded-lg transition-all hover:text-indigo-400">Skills</a></li>
                <li><a href="#projects" class="nav-link px-4 py-2 rounded-lg transition-all hover:text-indigo-400">Projets</a></li>
                <li><a href="#contact"  class="px-4 py-2 border-2 border-indigo-500 rounded-lg hover:bg-indigo-500 hover:text-white transition-all font-semibold">Contact</a></li>
            </ul>
            <button id="mobile-menu-btn" class="md:hidden text-indigo-400">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
                </svg>
            </button>
        </nav>
        <div id="mobile-menu" class="hidden md:hidden bg-slate-900/95 backdrop-blur-md border-b border-indigo-500/20">
            <ul class="flex flex-col gap-1 px-6 py-4 text-sm">
                <li><a href="#hero"     class="block px-4 py-2 rounded hover:text-indigo-400 transition">Accueil</a></li>
                <li><a href="#stack"    class="block px-4 py-2 rounded hover:text-indigo-400 transition">Stack</a></li>
                <li><a href="#skills"   class="block px-4 py-2 rounded hover:text-indigo-400 transition">Skills</a></li>
                <li><a href="#projects" class="block px-4 py-2 rounded hover:text-indigo-400 transition">Projets</a></li>
                <li><a href="#contact"  class="block px-4 py-2 border border-indigo-500 rounded hover:bg-indigo-500 transition">Contact</a></li>
            </ul>
        </div>
    </header>

    <main>{% block body %}{% endblock %}</main>

    <!-- ── FOOTER ── -->
    <footer class="bg-slate-950 border-t border-slate-800/60 py-10">
        <div class="max-w-6xl mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-6">
            <div>
                <p class="font-bold text-white text-base">{{ name }}</p>
                <p class="text-gray-400 text-sm flex items-center gap-2 mt-1">
                    <span>🇫🇷</span><span>Basée en Île-de-France</span>
                </p>
                <p class="text-gray-600 text-xs mt-2">&copy; {{ "now"|date("Y") }} {{ name }}. Tous droits réservés.</p>
            </div>
            <div class="flex items-center gap-5">
                <!-- GitHub -->
                <a href="https://github.com/Ketchuskana" target="_blank" aria-label="GitHub"
                   class="text-gray-400 hover:text-white transition-colors">
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.6.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.09-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.51 11.51 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
                    </svg>
                </a>
                <!-- LinkedIn -->
                <a href="https://www.linkedin.com/in/ketchuskana-son-essome/" target="_blank" aria-label="LinkedIn"
                   class="text-gray-400 hover:text-white transition-colors">
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                    </svg>
                </a>
                <!-- Email -->
                <a href="mailto:ketchuskanasonessomemoukouri@gmail.com" aria-label="Email"
                   class="text-gray-400 hover:text-white transition-colors">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                    </svg>
                </a>
            </div>
        </div>
    </footer>

    <script>
    // ── LOADER ──────────────────────────────────────────────────────────────
    window.addEventListener('load', () => {
        const bar  = document.getElementById('loader-bar');
        const pct  = document.getElementById('loader-pct');
        const wrap = document.getElementById('loader');
        let v = 0;

        const tick = () => {
            v = Math.min(v + Math.random() * 22 + 5, 90);
            bar.style.width = v + '%';
            pct.textContent = Math.floor(v) + '%';
            if (v < 90) setTimeout(tick, 180 + Math.random() * 120);
        };
        tick();

        setTimeout(() => {
            bar.style.width = '100%';
            pct.textContent = '100%';
            setTimeout(() => {
                wrap.style.transition = 'opacity .6s ease';
                wrap.style.opacity = '0';
                setTimeout(() => wrap.style.display = 'none', 650);
            }, 350);
        }, 2000);
    });

    // ── NAVBAR ──────────────────────────────────────────────────────────────
    window.addEventListener('scroll', () => {
        const nav = document.getElementById('navbar');
        if (window.scrollY > 50) {
            nav.style.background       = 'rgba(2,6,23,.92)';
            nav.style.borderBottom     = '1px solid rgba(79,70,229,.15)';
            nav.style.backdropFilter   = 'blur(14px)';
        } else {
            nav.style.background       = 'rgba(15,23,42,0)';
            nav.style.borderBottom     = 'none';
            nav.style.backdropFilter   = 'none';
        }
    });

    // mobile menu
    document.getElementById('mobile-menu-btn').addEventListener('click', () =>
        document.getElementById('mobile-menu').classList.toggle('hidden'));
    document.querySelectorAll('#mobile-menu a').forEach(a =>
        a.addEventListener('click', () => document.getElementById('mobile-menu').classList.add('hidden')));

    // smooth scroll
    document.querySelectorAll('a[href^="#"]').forEach(a =>
        a.addEventListener('click', e => {
            e.preventDefault();
            const t = document.querySelector(a.getAttribute('href'));
            if (t) t.scrollIntoView({ behavior:'smooth', block:'start' });
        }));

    // ── REVEAL ON SCROLL ────────────────────────────────────────────────────
    const observer = new IntersectionObserver(entries => {
        entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
    }, { threshold:.12 });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
    </script>
</body>
</html>
