<!DOCTYPE html>
<html lang="fr" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Portfolio | Backend Dev{% endblock %}</title>
    {% block stylesheets %}
        <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
    {% endblock %}
</head>
<body class="bg-slate-900 text-white overflow-hidden" id="body-content">

    <!-- Loader -->
    <div id="loader" class="fixed inset-0 z-[100] flex flex-col items-center justify-center bg-black transition-opacity duration-1000">
        <div class="text-4xl md:text-6xl font-black tracking-tighter animate-pulse">
            <span class="text-indigo-500">&lt;</span> {{ name|upper }} <span class="text-indigo-500">/&gt;</span>
        </div>
        <div class="mt-8 w-64 h-1 bg-slate-800 rounded-full overflow-hidden">
            <div id="loader-progress" class="h-full bg-indigo-500 w-0 transition-all duration-700 ease-in-out"></div>
        </div>
    </div>

    <!-- Header -->
    <header class="fixed top-0 w-full z-50 bg-slate-900/80 backdrop-blur-md border-b border-slate-800">
        <nav class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
            <div class="text-xl font-bold">Dev.<span class="text-indigo-500 italic">Backend</span></div>
            <ul class="hidden md:flex space-x-8 text-sm uppercase tracking-widest font-medium">
                <li><a href="#hero" class="hover:text-indigo-400 transition">Accueil</a></li>
                <li><a href="#stack" class="hover:text-indigo-400 transition">Stack</a></li>
                <li><a href="#skills" class="hover:text-indigo-400 transition">Skills</a></li>
                <li><a href="#projects" class="hover:text-indigo-400 transition">Projets</a></li>
                <li><a href="#contact" class="px-4 py-2 border border-indigo-500 rounded-lg hover:bg-indigo-500 transition">Contact</a></li>
            </ul>
        </nav>
    </header>

    <main>
        {% block body %}{% endblock %}
    </main>

    <footer class="bg-slate-950 py-12 border-t border-slate-800 text-center text-gray-500">
        <p>&copy; {{ "now"|date("Y") }} - {{ name }} | Backend Specialist</p>
    </footer>

    <script>
        window.addEventListener('load', () => {
            const loader = document.getElementById('loader');
            const progress = document.getElementById('loader-progress');
            const body = document.getElementById('body-content');

            progress.style.width = '100%';
            setTimeout(() => {
                loader.style.opacity = '0';
                setTimeout(() => {
                    loader.style.display = 'none';
                    body.classList.remove('overflow-hidden');
                }, 1000);
            }, 600);
        });
    </script>
</body>
</html>
