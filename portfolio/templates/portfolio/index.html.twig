{# ════════════════════════════════════════════
   CANVAS ANIMATIONS (skills + contact waves)
════════════════════════════════════════════ #}
<script>
(function () {
    'use strict';

    /* ── shared wave drawer ── */
    function makeWave(canvasId, opts) {
        const canvas = document.getElementById(canvasId);
        if (!canvas) return;
        const ctx  = canvas.getContext('2d');
        let t      = 0;
        let mx     = 0, my = 0;

        function resize() {
            canvas.width  = canvas.parentElement.offsetWidth  || window.innerWidth;
            canvas.height = canvas.parentElement.offsetHeight || window.innerHeight;
        }

        canvas.parentElement.addEventListener('mousemove', function(e) {
            const r = canvas.getBoundingClientRect();
            mx = e.clientX - r.left;
            my = e.clientY - r.top;
        });

        function draw() {
            const W = canvas.width, H = canvas.height;
            ctx.clearRect(0, 0, W, H);

            for (let i = 0; i < opts.lines; i++) {
                const prog  = i / opts.lines;
                const baseY = H * (opts.yStart + prog * opts.ySpread);
                const amp   = opts.ampBase + prog * opts.ampGrow + (my / (H || 1)) * opts.mouseAmp;
                const freq  = opts.freqBase + i * opts.freqStep;
                const phase = t * (opts.speed + i * opts.speedStep) + i * 0.6;
                const mfx   = ((mx / (W || 1)) - 0.5) * opts.mouseFx;

                ctx.beginPath();
                ctx.moveTo(0, baseY);
                for (let x = 0; x <= W; x += 4) {
                    const y = baseY
                        + Math.sin(x * freq + phase) * amp
                        + Math.sin(x * freq * 1.8 - phase * 0.55) * (amp * 0.38)
                        + mfx * Math.sin(x * 0.012 + phase * 0.5);
                    ctx.lineTo(x, y);
                }

                const hue     = opts.hueBase + prog * opts.hueRange;
                const opacity = opts.opBase  + prog * opts.opGrow;
                ctx.strokeStyle = `hsla(${hue},70%,65%,${opacity})`;
                ctx.lineWidth   = 1.4;
                ctx.stroke();
            }

            t += opts.tick;
            requestAnimationFrame(draw);
        }

        resize();
        window.addEventListener('resize', resize);
        draw();
    }

    /* ── Skills section (mariandev-style mesh) ── */
    makeWave('skills-canvas', {
        lines: 12, yStart: 0.05, ySpread: 0.92,
        ampBase: 14, ampGrow: 7,  mouseAmp: 22,
        freqBase: 0.006, freqStep: 0.0007,
        speed: 0.18, speedStep: 0.025,
        mouseFx: 28,
        hueBase: 240, hueRange: 55,
        opBase: 0.035, opGrow: 0.055,
        tick: 0.009
    });

    /* ── Contact section ── */
    makeWave('contact-canvas', {
        lines: 9, yStart: 0.08, ySpread: 0.86,
        ampBase: 18, ampGrow: 9,  mouseAmp: 0,
        freqBase: 0.005, freqStep: 0.0009,
        speed: 0.14, speedStep: 0.018,
        mouseFx: 0,
        hueBase: 248, hueRange: 40,
        opBase: 0.04, opGrow: 0.04,
        tick: 0.007
    });
})();
</script>

